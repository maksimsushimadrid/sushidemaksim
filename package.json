{
    "name": "sushi-bar-online",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
        "dev:client": "vite",
        "dev:server": "cd server && npm run dev",
        "sitemap": "node scripts/generate-sitemap.js",
        "build": "tsc && npm run sitemap && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --no-cache",
        "lint:fix": "eslint . --ext ts,tsx --fix",
        "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,json,css,md}\"",
        "preview": "vite preview",
        "test": "vitest run && npx playwright test",
        "test:unit": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "npx playwright test"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hookform/resolvers": "^5.2.2",
        "@react-email/components": "^1.0.8",
        "@react-email/render": "^2.0.4",
        "@react-oauth/google": "^0.13.5",
        "@supabase/supabase-js": "^2.98.0",
        "@tanstack/react-query": "^5.91.0",
        "@turf/turf": "^7.3.4",
        "@types/leaflet": "^1.9.3",
        "@types/leaflet-draw": "^1.0.11",
        "@types/qrcode": "^1.5.6",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "axios": "^1.7.9",
        "bcryptjs": "^2.4.3",
        "clsx": "^2.0.0",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^17.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.0",
        "framer-motion": "^12.35.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "leaflet": "^1.9.4",
        "leaflet-draw": "^1.0.4",
        "lenis": "^1.3.18",
        "lucide-react": "^0.294.0",
        "morgan": "^1.10.1",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.1",
        "pg": "^8.20.0",
        "qrcode": "^1.5.4",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-google-recaptcha-v3": "^1.11.0",
        "react-helmet-async": "^3.0.0",
        "react-hook-form": "^7.72.1",
        "react-leaflet": "^4.2.1",
        "react-leaflet-draw": "^0.20.4",
        "react-qr-code": "^2.0.18",
        "react-router-dom": "^6.20.1",
        "recharts": "^3.8.0",
        "resend": "^6.9.4",
        "sharp": "^0.34.5",
        "tailwind-merge": "^3.5.0",
        "ua-parser-js": "^2.0.9",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.10",
        "@types/multer": "^2.0.0",
        "@types/nodemailer": "^7.0.11",
        "@types/pg": "^8.18.0",
        "@types/react": "^18.2.37",
        "@types/react-dom": "^18.2.15",
        "@types/sharp": "^0.31.1",
        "@types/ua-parser-js": "^0.7.39",
        "@typescript-eslint/eslint-plugin": "^6.10.0",
        "@typescript-eslint/parser": "^6.10.0",
        "@vitejs/plugin-react": "^4.1.1",
        "@vitest/coverage-v8": "^1.6.0",
        "@vitest/ui": "^1.6.0",
        "autoprefixer": "^10.4.16",
        "concurrently": "^9.2.1",
        "eslint": "^8.53.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.4",
        "jsdom": "^28.1.0",
        "postcss": "^8.4.31",
        "prettier": "^3.8.1",
        "tailwindcss": "^3.3.5",
        "tsx": "^4.21.0",
        "typescript": "^5.2.2",
        "vite": "^4.5.3",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^1.6.0"
    }
}
