{
    "version": 2,
    "redirects": [
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "sushidemaksim.vercel.app"
                }
            ],
            "destination": "https://www.sushidemaksim.com/$1",
            "permanent": true
        },
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "sushidemaksim.com"
                }
            ],
            "destination": "https://www.sushidemaksim.com/$1",
            "permanent": true
        },

        {
            "source": "/blog/:slug",
            "destination": "/tablon",
            "permanent": true
        },
        {
            "source": "/blog",
            "destination": "/tablon",
            "permanent": true
        },
        {
            "source": "/contacto",
            "destination": "/contacts",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/api/[...path]"
        },
        {
            "source": "/merchant-feed.xml",
            "destination": "/api/[...path]"
        },
        {
            "source": "/robots.txt",
            "destination": "/robots.txt"
        },
        {
            "source": "/google(.*).html",
            "destination": "/google$1.html"
        },
        {
            "source": "/invitacion/(.*)",
            "destination": "/api/[...path]"
        },
        {
            "source": "/compartir/(.*)",
            "destination": "/api/[...path]"
        },
        {
            "source": "/api/threads/(.*)",
            "destination": "/api/[...path]"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/[...path]"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/check-late-orders",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/cron/check-birthdays",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/generate-daily-report",
            "schedule": "5 0 * * *"
        },
        {
            "path": "/api/cron/cleanup-deleted-users",
            "schedule": "0 3 * * *"
        }
    ],
    "images": {
        "sizes": [256, 640, 1080, 1920],
        "domains": ["images.unsplash.com"],
        "minimumCacheTTL": 2592000,
        "formats": ["image/avif", "image/webp"],
        "remotePatterns": [
            {
                "protocol": "https",
                "hostname": "*.supabase.co"
            },
            {
                "protocol": "https",
                "hostname": "lmuytpvktanykcubpodh.supabase.co"
            },
            {
                "protocol": "https",
                "hostname": "images.unsplash.com"
            }
        ]
    },
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cross-Origin-Opener-Policy",
                    "value": "same-origin-allow-popups"
                }
            ]
        },
        {
            "source": "/(assets|images|fonts|icons)/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*).(jpg|jpeg|png|webp|avif|gif|svg|ico|woff|woff2|ttf|otf)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(sw.js|version.json)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate, no-cache, no-store"
                }
            ]
        }
    ]
}
